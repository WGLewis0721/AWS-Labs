# envs/template.env
# Copy this file to envs/<environment-name>.env and fill in the values.
# Every value here can also be set as a shell environment variable before
# running the script — shell env vars take precedence over this file.

# ── AWS ───────────────────────────────────────────────────────────────────────
REGION="us-east-1"
PROJECT_TAG="tgw-segmentation-lab"

# ── IPs ───────────────────────────────────────────────────────────────────────
# Private IP of the B1 management interface
B1_MGMT_IP="10.1.3.10"

# CIDR of the VPC where the jump host (A2) lives
VPC_A_CIDR="10.0.0.0/16"

# CIDR of the VPC where B1 lives
VPC_B_CIDR="10.1.0.0/16"

# ── Resource tag names ────────────────────────────────────────────────────────
# The script looks up resource IDs by these Name tags at runtime.
# Change these if your environment uses different naming conventions.
B1_INSTANCE_TAG_NAME="lab-b1-paloalto"
RT_A_TAG_NAME="lab-rt-a"
TGW1_ATTACH_B_TAG_NAME="tgw1-attach-vpc-b"
SG_PALO_MGMT_NAME="lab-sg-palo-mgmt"
NACL_A_TAG_NAME="nacl-a"
NACL_B_MGMT_TAG_NAME="nacl-b-mgmt"

# ── SSH ───────────────────────────────────────────────────────────────────────
SSH_USER="ec2-user"
KEY_PATH="/home/ec2-user/tgw-lab-key.pem"
SSH_TIMEOUT="10"

# ── B1 service names ──────────────────────────────────────────────────────────
# systemd service names checked via SSM on B1
B1_MULTI_ENI_SERVICE="lab-multi-eni"
B1_WEB_SERVICE="lab-web"
