# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform crash logs
crash.log
crash.*.log
tfplan
*.tfplan

# Ignore tfvars with secrets by default
*.tfvars
*.auto.tfvars.json
!*.tfvars.example

# Ignore local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock info
.terraform.tfstate.lock.info

# CLI config files
.terraformrc
terraform.rc
